{
  "name": "@nemesis/desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Nemesis Launcher Desktop Application",
  "author": "Nemesis Team",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:renderer": "electron-vite dev --mode renderer",
    "build": "electron-vite build",
    "build:unpack": "pnpm build && electron-builder --dir",
    "build:mac": "pnpm build && electron-builder --mac",
    "build:win": "pnpm build && electron-builder --win",
    "build:linux": "pnpm build && electron-builder --linux",
    "release": "pnpm build && electron-builder --publish never",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "clean": "rm -rf dist release out",
    "rebuild:keytar": "electron-rebuild -f -w keytar"
  },
  "dependencies": {
    "@nemesis/shared": "workspace:*",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.0",
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.47",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.28.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  },
  "build": {
    "extends": "./electron-builder.yml"
  }
}
