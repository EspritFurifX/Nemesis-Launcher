# ===========================================
# NEMESIS LAUNCHER - ENVIRONMENT VARIABLES
# ===========================================
# Copier ce fichier en .env et remplir les valeurs

# ===========================================
# DATABASE
# ===========================================
# Option 1: PostgreSQL via Docker
DATABASE_URL="postgresql://nemesis:nemesis_secure_pwd@localhost:5432/nemesis_db?schema=public"

# Option 2: SQLite pour dev rapide (décommenter)
# DATABASE_URL="file:./dev.db"

# ===========================================
# MICROSOFT OAUTH2
# ===========================================
# Créer une app sur https://portal.azure.com
# Azure AD > App registrations > New registration
# Redirect URI: http://localhost:3000/auth/callback (web)
# Redirect URI: http://localhost:45678/auth/callback (desktop)
MICROSOFT_CLIENT_ID="your-azure-app-client-id"
MICROSOFT_CLIENT_SECRET="your-azure-app-client-secret"

# ===========================================
# JWT / SESSIONS
# ===========================================
# Générer avec: openssl rand -base64 32
JWT_SECRET="change-this-to-a-random-32-char-string"
JWT_EXPIRES_IN="7d"

# ===========================================
# API
# ===========================================
API_HOST="localhost"
API_PORT=4000
API_URL="http://localhost:4000"

# ===========================================
# WEB (Next.js)
# ===========================================
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ===========================================
# DESKTOP (Electron)
# ===========================================
# Port du serveur OAuth local pour le desktop
DESKTOP_OAUTH_PORT=45678

# URL du CDN local pour les releases
LOCAL_CDN_URL="http://localhost:4000/cdn"

# ===========================================
# LOCAL CDN / RELEASES
# ===========================================
CDN_STORAGE_PATH="./storage/cdn"

# ===========================================
# DEVELOPMENT
# ===========================================
NODE_ENV="development"
LOG_LEVEL="debug"

# ===========================================
# SECURITY (dev only)
# ===========================================
# Désactiver HTTPS en dev local
DISABLE_HTTPS="true"

# Clé de chiffrement pour tokens stockés localement
# Générer avec: openssl rand -hex 32
ENCRYPTION_KEY="change-this-64-char-hex-string-for-local-token-encryption"
