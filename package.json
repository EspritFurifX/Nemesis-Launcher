{
  "name": "nemesis-launcher",
  "version": "1.0.0",
  "private": true,
  "description": "Némésis Launcher - Launcher Minecraft avec authentification Microsoft",
  "author": "Némésis Launcher",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev --parallel --filter=!@nemesis/desktop",
    "dev:web": "turbo run dev --parallel --filter=!@nemesis/desktop",
    "dev:full": "turbo run dev --parallel",
    "dev:api": "turbo run dev --filter=@nemesis/api",
    "dev:www": "turbo run dev --filter=@nemesis/www",
    "dev:sites": "turbo run dev --filter=@nemesis/app --filter=@nemesis/cdn-web --filter=@nemesis/docs --filter=@nemesis/status --filter=@nemesis/blog --filter=@nemesis/admin --filter=@nemesis/play --parallel",
    "dev:all": "turbo run dev --parallel",
    "dev:desktop": "turbo run dev --filter=@nemesis/desktop",
    "dev:fast": "./scripts/dev-precompile.sh",
    "precompile": "turbo run build && turbo run dev --parallel --concurrency=4",
    "build": "turbo run build",
    "build:api": "turbo run build --filter=@nemesis/api",
    "build:sites": "turbo run build --filter=@nemesis/www --filter=@nemesis/app --filter=@nemesis/cdn-web --filter=@nemesis/docs --filter=@nemesis/status --filter=@nemesis/blog --filter=@nemesis/admin --filter=@nemesis/play",
    "build:desktop": "turbo run build --filter=@nemesis/desktop",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "db:generate": "turbo run db:generate --filter=@nemesis/database",
    "db:push": "turbo run db:push --filter=@nemesis/database",
    "db:studio": "turbo run db:studio --filter=@nemesis/database",
    "release:desktop": "pnpm --filter @nemesis/desktop run release",
    "release:local": "./scripts/release-local.sh"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "turbo": "^2.3.0",
    "typescript": "^5.5.0"
  }
}
